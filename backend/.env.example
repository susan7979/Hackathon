# Copy this file to `.env` in this folder (backend/) or use a `.env` in the project root.
# Never commit real keys — `.env` should be gitignored.

# Required for signup/login JWTs (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
